{
  "manifest_version": 3,
  "name": "Global Web Theme Switcher",
  "description": "Apply a consistent light or dark theme style across websites.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Theme Switcher",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
