{
  "manifest_version": 3,
  "name": "ForcedSkin — Web Theme Switcher",
  "short_name": "ForcedSkin",
  "description": "Apply your favorite light or dark color theme to any website. Log in to forcedskin.com to sync custom themes across devices.",
  "version": "0.2.0",
  "homepage_url": "https://forcedskin.com",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "ForcedSkin",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/engine.js",
        "src/content/adapters/bilibili.js",
        "src/content/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
