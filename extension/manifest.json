{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "__MSG_extShortName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "0.1.3",
  "homepage_url": "https://forcedskin.com",
  "icons": {
    "16": "src/favicon.ico",
    "48": "src/LOGO.webp",
    "128": "src/LOGO.webp"
  },
  "permissions": [
    "alarms",
    "storage",
    "scripting",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "ForcedSkin",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/favicon.ico",
      "48": "src/LOGO.webp",
      "128": "src/LOGO.webp"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/engine.js",
        "src/content/adapter-formula.js",
        "src/content/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}